# Create .env.development or .env.production and add the following line:
DB_URL=
DB_DRIVER=
PORT=
JWT_SECRET=

FRONTEND_ORIGIN=

# Google cloud Geocode API
GEOCODE_API_KEY=
# Gemini API
GEMINI_API_KEY=

# Stripe
STRIPE_SECRET_API_KEY=

# OneSignal
ONESIGNAL_REST_API_KEY=
ONESIGNAL_APP_ID=

# SMTP (hMailServer)
SMTP_HOST=mail.upcycleconnect.lan
SMTP_PORT=25
SMTP_USER=noreply@upcycleconnect.lan
SMTP_PASSWORD=
SMTP_FROM=noreply@upcycleconnect.lan

# Public base URL of this API, used to build links sent by email (e.g. verify-email)
BACKEND_ORIGIN=http://localhost:8080